# ─── LLM ────────────────────────────────────────────────
JARVINX_MODEL=llama3.1:8b          # Modèle Ollama utilisé pour les décisions
JARVINX_INTERVAL=20s               # Fréquence du cycle observe→decide→act

# ─── FILE AGENT ─────────────────────────────────────────
JARVINX_FILE_WATCH=/chemin/dossier1,/chemin/dossier2  # Dossiers à surveiller (vide = désactivé)
JARVINX_FILE_MAX_MB=500            # Alerte si un fichier dépasse ce seuil en MB

# ─── SEUILS D'ALERTE ────────────────────────────────────
JARVINX_CPU_THRESHOLD=75           # Alerte si CPU dépasse ce % 
JARVINX_RAM_THRESHOLD=90           # Alerte si RAM dépasse ce %
JARVINX_DISK_THRESHOLD=85          # Alerte si Disk dépasse ce %

# ─── NOTIFICATIONS ──────────────────────────────────────
DISCORD_WEBHOOK=...                # Webhook Discord pour les alertes
NTFY_URL=https://ntfy.sh           # Serveur Ntfy (défaut : ntfy.sh public)
NTFY_TOPIC=jarvinx                 # Topic Ntfy pour recevoir les notifs

# ─── RAPPORT QUOTIDIEN ──────────────────────────────────
JARVINX_DAILY_REPORT=true          # Activer le rapport quotidien
JARVINX_REPORT_HOUR=8              # Heure d'envoi (format 24h)
JARVINX_REPORT_MINUTE=0            # Minute d'envoi

# ─── RÉSEAU ─────────────────────────────────────────────
JARVINX_ALLOWED_ORIGINS=http://192.168.1.X:3000,http://100.X.X.X:3000  # CORS dashboard

# ─── PERSISTANCE ────────────────────────────────────────
JARVINX_SQLITE_PATH=jarvinx.db     # Fichier SQLite — historique illimité des cycles

# ─── MÉMOIRE SÉMANTIQUE (v1.8) ──────────────────────────
JARVINX_QDRANT_URL=http://localhost:6333  # URL Qdrant — laisser vide pour désactiver
JARVINX_EMBED_MODEL=nomic-embed-text      # Modèle Ollama pour les embeddings

# ─── DEBUG ──────────────────────────────────────────────
JARVINX_DEBUG=false                # true = logs détaillés dans la console